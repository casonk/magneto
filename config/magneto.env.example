# Local runtime config for magneto.
# Copy to config/magneto.env.local and edit host-specific values.

MAGNETO_HOST=127.0.0.1
MAGNETO_PORT=5400
MAGNETO_SECRET_KEY=change-this-local-secret
MAGNETO_PUBLIC_ORIGIN=https://torrents.snowbridge.internal

MAGNETO_TRANSMISSION_URL=http://127.0.0.1:9091/transmission/rpc
# Normal local setup resolves Transmission RPC auth from auto-pass.
MAGNETO_TRANSMISSION_KEEPASS_PROFILE=infra
MAGNETO_TRANSMISSION_KEEPASS_ENTRY=magneto@transmission
# Optional explicit overrides. Leave blank to use the KeePassXC UserName/Password fields.
MAGNETO_TRANSMISSION_USERNAME=
MAGNETO_TRANSMISSION_PASSWORD=
MAGNETO_REQUEST_TIMEOUT=10

MAGNETO_DOWNLOAD_DIR=/srv/snowbridge/share/torrents

# Optional torrent completion/error notifications through shock-relay.
# Leave target blank to keep notifications disabled. Target is service-specific:
# Signal/Twilio phone number, Telegram chat ID, WhatsApp recipient, or email address.
MAGNETO_NOTIFY_ENABLED=0
# Set MAGNETO_SHOCK_RELAY_ROOT to the absolute path of util-repos/shock-relay on this machine.
# Record the value in REFS-LOCAL.md rather than committing it here.
MAGNETO_SHOCK_RELAY_ROOT=
MAGNETO_NOTIFY_TAG=magneto/notify
MAGNETO_NOTIFY_SERVICE=signal
MAGNETO_NOTIFY_TARGET=
MAGNETO_NOTIFY_CONFIG=
MAGNETO_NOTIFY_SIGNAL_TARGET=
MAGNETO_NOTIFY_SIGNAL_CONFIG=
MAGNETO_NOTIFY_EMAIL_TARGET=
MAGNETO_NOTIFY_EMAIL_CONFIG=
MAGNETO_NOTIFY_STATE_FILE=
