# Runtime defaults for the Transmission VPN guard.
# Copy to /etc/magneto/transmission-vpn-guard.env when installing manually.

TRANSMISSION_USER=transmission
TRANSMISSION_UID=
VPN_INTERFACE=nordlynx
RPC_PORT=9091
NFT_TABLE=magneto_transmission_vpn_guard

# NordLynx/WireGuard encapsulates accepted tunnel traffic as marked UDP packets
# to the VPN server over the physical interface. These are still VPN packets.
ALLOW_VPN_TRANSPORT=1
VPN_TRANSPORT_FWMARK=0xe1f1
VPN_TRANSPORT_PORT=51820

# Keep disabled for the strictest DNS-leak posture. Enable only if tracker DNS
# resolution fails and your host DNS is already forced through the VPN.
ALLOW_LOCAL_DNS=0

# Allow Transmission to query the local systemd-resolved stub only.
ALLOW_LOOPBACK_DNS=1

# Temporary diagnostics only. Prefer scripts/diagnose_transmission_vpn.sh.
LOG_REJECTS=0
